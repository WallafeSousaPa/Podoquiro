# Copie para .env.local e preencha (nunca commite segredos reais).
# Na Vercel: Project → Settings → Environment Variables (mesmos nomes).

# Supabase — Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key_aqui

# Segredo para JWT da sessão (string longa e aleatória, ex.: openssl rand -base64 48)
AUTH_SECRET=

# NF-e direto SEFAZ (integração própria)
# Emitente Pará (PA): autorização pelo SVRS (URLs em lib/sefaz/nfe).
NFE_UF=PA
# NFE_AMBIENTE: 1 = produção, 2 = homologação (use 2 até homologar)
NFE_AMBIENTE=2
# Chave secreta para cifrar .pfx e senha gravados na tabela empresa_nfe_certificados (string longa)
NFE_CERT_MASTER_KEY=7c0UvXo4HRsNrB78VPsWE4Z5SmOAyIycqMjSesPovrqqhxSKIIa5wnTFvFf9BT6D
# Opcional (legado): certificado só por arquivo no disco, sem usar o banco
NFE_CERT_PATH=
NFE_CERT_PASSWORD=
# Opcional: PEM extra (além da AC Raiz ICP-Brasil v10 já embutida no app para SVRS).
# Caminho absoluto ou arquivo sob certs-nfe/. Alternativa: NODE_EXTRA_CA_CERTS=...
NFE_EXTRA_CA_CERTS_PATH=
# Só diagnóstico (homologação): 1 = não valida certificado TLS do servidor (inseguro; não use em produção)
# NFE_TLS_INSECURE_SKIP_VERIFY=

# Emissão de teste (homologação): IE do emitente — só dígitos (2–14) ou a palavra **ISENTO** (não use só máscara vazia após remover pontos)
NFE_EMITENTE_IE=
# Código IBGE do município do emitente (7 dígitos). Padrão Belém/PA se vazio.
# NFE_EMITENTE_CMUN=1501402
# CRT: 1 = Simples Nacional (padrão). NFE_SERIE padrão 1.
# NFE_EMITENTE_CRT=1
# NFE_SERIE=1
# NFCE_SERIE: série da NFC-e (modelo 65). Se vazio, usa NFE_SERIE.
# NFCE_SERIE=1

# NFC-e (modelo 65) — QR Code: CSC e identificador do CSC, gerados no portal da SEFA-PA.
# Obrigatórios para emitir NFC-e. O CSC de homologação é diferente do de produção.
NFE_CSC=
NFE_CSC_ID=
# CPF destinatário fictício e valor da nota de teste (opcional)
# NFE_TESTE_CPF_DEST=11144477735
# NFE_TESTE_VALOR=1.00
# NCM 8 dígitos existente na TIPI (opcional; padrão no código evita rejeição 778)
# NFE_TESTE_NCM=73269090

# NFS-e via Notaas (https://docs.notaas.com.br/docs)
# NOTAAS_API_KEY=ntaas_XXXXXXXXXXXXXXXXXXXXXXXXXXXX
# NOTAAS_BASE_URL=https://platform.notaas.com.br/api/v1
# Código LC 116 (6 dígitos) e alíquota ISS padrão para emissão de serviço
# NOTAAS_CODIGO_SERVICO=060101
# NOTAAS_CNAE=869090400
# NOTAAS_ALIQUOTA_ISS=2.0
# Opcional: sincroniza CNAE/código LC 116 no projeto Notaas ao salvar Parâmetros (Org API)
# NOTAAS_ORG_TOKEN=ntaas_org_XXXXXXXXXXXXXXXXXXXXXXXXXXXX
# NOTAAS_PROJECT_ID=uuid-do-projeto-no-painel-notaas

# NFS-e via Focus NFe (https://focusnfe.com.br/doc/)
# Token HTTP Basic (usuário = token, senha vazia). Pode ser gravado cifrado em Parâmetros na tela Emissão.
# FOCUSNFE_TOKEN=
# Ambiente e prestador são configurados em Nota Fiscal → Emissão → Parâmetros Focus NFe.
